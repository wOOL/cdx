{
	"name": "codiagnostix-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev",
		"build": "bun run build:cad && bun --bun vite build",
		"preview": "bun --bun vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"build:cad": "bun run scripts/build-cad.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/bun": "^1.3.14",
		"@types/three": "^0.184.1",
		"playwright": "^1.60.0",
		"svelte": "^5.56.1",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"dicom-parser": "^1.8.21",
		"fflate": "^0.8.3",
		"three": "^0.184.0"
	}
}